<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ZOMBIX BORSA | BORDO v9.5 (SYSTEM_BREACH_EDITION)</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');
        
        /* TEMA DEĞİŞKENLERİ (Varsayılan: NEON GOLD) */
        :root {
            --neon-gold: #ffcc00;   /* Ana Vurgu Rengi */
            --neon-green: #00ff66;  /* Yükseliş / Pozitif */
            --neon-red: #ff3333;    /* Düşüş / Negatif */
            --bg-deep: #050507; 
            --terminal-glass: rgba(15, 15, 20, 0.95);
        }

        /* TEMA 2: FISTIK YEŞİLİ (TOXIC/ACID) */
        [data-theme="pistachio"] {
            --neon-gold: #ccff00;   /* Fıstık/Asit Yeşili - Ana Vurgu */
            --neon-green: #66ff66;  /* Daha yumuşak bir yeşil */
            --neon-red: #ff5555;    /* Pastel Kırmızı */
        }

        /* TEMA 3: OKYANUS MAVİSİ (CYAN/DEEP SEA) */
        [data-theme="ocean"] {
            --neon-gold: #00e5ff;   /* Camgöbeği/Okyanus - Ana Vurgu */
            --neon-green: #00ffaa;  /* Akuamarin */
            --neon-red: #ff0055;    /* Koyu Pembe/Kırmızı (Mavi ile uyumlu) */
        }

        * { box-sizing: border-box; }
        body {
            background: var(--bg-deep); color: #ccc; font-family: 'Share Tech Mono', monospace;
            margin: 0; display: flex; flex-direction: column; min-height: 100vh; overflow-x: hidden;
            transition: background 0.3s;
        }
        body::before {
            content: " "; position: fixed; top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.15) 50%);
            background-size: 100% 4px; pointer-events: none; z-index: 1000;
        }

        /* EFEKTLER */
        .pump-effect { background: rgba(255, 204, 0, 0.15) !important; animation: goldGlow 1.5s infinite alternate; border-bottom: 1px solid var(--neon-gold) !important; }
        
        @keyframes goldGlow { from { box-shadow: inset 0 0 2px var(--neon-gold); } to { box-shadow: inset 0 0 15px var(--neon-gold); } }
        
        .dump-effect { background: rgba(255, 51, 51, 0.15) !important; animation: redAlert 0.8s infinite alternate; border-bottom: 1px solid var(--neon-red) !important; }
        @keyframes redAlert { from { opacity: 1; } to { opacity: 0.8; box-shadow: inset 0 0 15px var(--neon-red); } }
        .trend-label { font-size: 8px; font-weight: bold; margin-left: 5px; padding: 1px 3px; border: 1px solid currentColor; border-radius: 2px; }

        #market-status-indicator { position: fixed; bottom: 15px; left: 15px; z-index: 999; background: rgba(0,0,0,0.7); border: 1px solid var(--neon-gold); padding: 5px 10px; font-size: 10px; display: flex; align-items: center; gap: 8px; border-radius: 2px; pointer-events: none; }
        .status-dot { width: 6px; height: 6px; border-radius: 50%; }
        .status-open { background: var(--neon-green); box-shadow: 0 0 8px var(--neon-green); }
        .status-closed { background: var(--neon-red); box-shadow: 0 0 8px var(--neon-red); }

        #announcement-bar { display: none; background: #000; color: var(--neon-red); padding: 10px; text-align: center; font-weight: bold; font-size: 14px; border-top: 1px solid var(--neon-red); border-bottom: 1px solid var(--neon-red); text-transform: uppercase; letter-spacing: 3px; box-shadow: inset 0 0 15px rgba(255, 51, 51, 0.2); text-shadow: 0 0 8px var(--neon-red); animation: alertPulse 2s infinite; }
        @keyframes alertPulse { 0% { border-color: #600; box-shadow: inset 0 0 5px rgba(255, 51, 51, 0.1); } 50% { border-color: var(--neon-red); box-shadow: inset 0 0 20px rgba(255, 51, 51, 0.3); } 100% { border-color: #600; box-shadow: inset 0 0 5px rgba(255, 51, 51, 0.1); } }

        #news-bot-sticky { display: none; background: var(--neon-gold); color: #000; padding: 10px; text-align: center; font-weight: bold; font-size: 13px; border-bottom: 2px solid #000; box-shadow: 0 0 15px var(--neon-gold); position: sticky; top: 0; z-index: 100; animation: flash 1s infinite alternate; }
        @keyframes flash { from { opacity: 0.8; } to { opacity: 1; } }

        .vip-name { color: var(--neon-gold) !important; text-shadow: 0 0 10px var(--neon-gold); font-weight: bold; }
        .vip-icon { margin-right: 4px; }

        .reply-container { background: rgba(255, 204, 0, 0.1); border-left: 2px solid var(--neon-gold); padding: 5px; margin-bottom: 5px; font-size: 11px; color: #888; display: none; position: relative; }
        .reply-content { font-style: italic; }
        .cancel-reply { position: absolute; right: 5px; top: 2px; color: var(--neon-red); cursor: pointer; }
        .msg-reply-box { background: rgba(255,255,255,0.05); border-left: 2px solid #555; padding: 3px 6px; font-size: 11px; margin-bottom: 4px; color: #aaa; }

        #admin-panel { display: none; background: #000; border: 2px solid var(--neon-red); padding: 15px; margin: 10px; z-index: 10001; }
        #auth-screen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--bg-deep); z-index: 9999; display: flex; justify-content: center; align-items: center; flex-direction: column; }
        .auth-box { background: var(--terminal-glass); border: 2px solid var(--neon-gold); padding: 30px; width: 90%; max-width: 380px; text-align: center; }

        .news-ticker { background: rgba(255, 204, 0, 0.1); color: var(--neon-gold); padding: 8px 0; border-bottom: 1px solid var(--neon-gold); white-space: nowrap; overflow: hidden; font-size: 12px; position: relative; }
        .ticker-text { display: inline-block; padding-left: 100%; animation: ticker 60s linear infinite; }
        @keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-100%); } }
        
        .dashboard { display: none; flex-direction: column; gap: 15px; padding: 15px; flex: 1; padding-bottom: 20px; }
        @media (min-width: 992px) { .dashboard { grid-template-columns: 1fr 380px; display: none; flex-direction: row; } }

        .main-panel, .side-panel { background: var(--terminal-glass); border: 1px solid rgba(255, 204, 0, 0.3); padding: 15px; border-color: var(--neon-gold); }

        /* CHAT & DM STYLES */
        .chat-container { margin-top: 15px; border: 1px solid var(--neon-gold); height: 450px; display: flex; flex-direction: column; }
        .chat-header-tabs { display: flex; background: rgba(0,0,0,0.8); border-bottom: 1px solid var(--neon-gold); }
        .chat-tab { flex: 1; padding: 10px; text-align: center; color: #555; cursor: pointer; font-weight: bold; font-size: 12px; transition: 0.3s; }
        .chat-tab.active { background: rgba(255, 204, 0, 0.2); color: var(--neon-gold); border-bottom: 2px solid var(--neon-gold); }
        .online-status-box { padding:10px; display:flex; align-items:center; cursor: pointer; transition: 0.3s; }
        .online-status-box:hover { background: rgba(255, 255, 255, 0.1); }

        #chat-content-area { flex: 1; overflow-y: auto; background: rgba(0,0,0,0.4); position: relative; }
        
        #global-view { display: block; height: auto; min-height: 100%; padding: 10px; }
        #dm-view { display: none; height: 100%; flex-direction: column; }
        
        .chat-msg { margin-bottom: 10px; border-bottom: 1px solid #222; padding-bottom: 5px; word-wrap: break-word; position: relative; cursor: pointer; }
        .chat-img { max-width: 100%; border: 1px solid var(--neon-gold); margin-top: 5px; display: block; border-radius: 4px; cursor: pointer; }
        .msg-admin { color: var(--neon-red); }
        .msg-user { color: var(--neon-gold); }
        .msg-dm-self { text-align: right; color: var(--neon-green); border-bottom: 1px solid #333; margin-bottom: 8px; padding-bottom:4px; }
        .msg-dm-other { text-align: left; color: var(--neon-gold); border-bottom: 1px solid #333; margin-bottom: 8px; padding-bottom:4px; }
        .user-label { font-weight: bold; }
        
        .del-msg { color: #555; cursor: pointer; font-size: 9px; margin-left: 8px; vertical-align: middle; }
        .del-msg:hover { color: var(--neon-red); }

        .chat-input-area { display: flex; border-top: 1px solid var(--neon-gold); flex-wrap: wrap; flex-direction: column; }
        .input-row { display: flex; width: 100%; }
        #chat-input { background: transparent; border: none; color: #fff; padding: 10px; flex: 1; min-width: 120px; }
        .chat-tool-btn { width: 35px; border: none; background: transparent; color: var(--neon-gold); cursor: pointer; border-left: 1px solid #333; font-size: 16px; display: flex; align-items: center; justify-content: center; }
        #chat-send { width: 45px; border: none; background: var(--neon-gold); color: #000; font-weight: bold; cursor: pointer;}
        
        #emoji-picker { display: none; background: #111; border-top: 1px solid var(--neon-gold); padding: 5px; justify-content: center; gap: 5px; width: 100%; }
        .emoji-btn { background: none; border: none; cursor: pointer; font-size: 18px; padding: 5px; width: auto; margin: 0; }

        /* DM LIST STYLES */
        #dm-list-container { padding: 10px; }
        .dm-item { padding: 10px; border: 1px solid #333; margin-bottom: 5px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.02); }
        .dm-item:hover { border-color: var(--neon-gold); background: rgba(255,204,0,0.05); }
        #dm-conversation-container { display: none; flex: 1; overflow-y: auto; padding: 10px; }
        .dm-header-bar { padding: 5px 10px; background: #111; border-bottom: 1px solid var(--neon-gold); display: flex; align-items: center; justify-content: space-between; font-size: 11px; display:none;} 

        .trade-section { border: 1px solid var(--neon-gold); margin-top: 15px; background: rgba(255, 204, 0, 0.05); padding: 10px; }
        #trade-feed { height: 180px; overflow-y: auto; background: rgba(0,0,0,0.4); margin-top: 8px; border: 1px solid rgba(255,204,0,0.2); font-size: 11px; }
        .trade-item-card { border-bottom: 1px solid #222; padding: 8px 5px; line-height: 1.4; position: relative; }
        .price-diff-badge { font-size: 9px; font-weight: bold; margin-top: 2px; }

        #confirm-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 30000; align-items: center; justify-content: center; }
        .confirm-box { background: #000; border: 2px solid var(--neon-red); padding: 20px; text-align: center; width: 280px; box-shadow: 0 0 20px rgba(255, 51, 51, 0.3); }

        .price-up { color: var(--neon-green) !important; }
        .price-down { color: var(--neon-red) !important; }
        input, select, button { background: #000; border: 1px solid var(--neon-gold); color: var(--neon-gold); padding: 10px; width: 100%; margin-bottom: 10px; font-family: inherit; }
        .error-msg { color: var(--neon-red); font-size: 12px; margin-bottom: 10px; display: none; }
        .logout-btn { background: transparent; border: 1px solid var(--neon-red); color: var(--neon-red); padding: 2px 8px; font-size: 10px; cursor: pointer; width: auto; margin-left: 10px; }
        .footer-legal { padding: 20px; text-align: center; font-size: 10px; color: #444; border-top: 1px solid #111; line-height: 1.5; }
        .online-dot { height: 8px; width: 8px; background-color: var(--neon-green); border-radius: 50%; display: inline-block; margin-right: 5px; box-shadow: 0 0 8px var(--neon-green); animation: blink 1.5s infinite; }
        @keyframes blink { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
        
        #online-modal, #img-viewer, #new-dm-modal { display: none; position: fixed; z-index: 20000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); backdrop-filter: blur(5px); }
        .modal-content { background: #000; border: 1px solid var(--neon-gold); margin: 10% auto; padding: 20px; width: 300px; text-align: center; box-shadow: 0 0 20px rgba(255, 204, 0, 0.2); display: flex; flex-direction: column; max-height: 80vh; }
        .viewer-box { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 20px; }
        #viewer-img { max-width: 95%; max-height: 80%; border: 1px solid var(--neon-gold); }
        #marketSearch { margin-bottom: 15px; background: rgba(255, 204, 0, 0.05); border-style: dashed; font-size: 12px; }
        .market-table td { padding: 12px 5px; border-bottom: 1px solid rgba(255, 255, 255, 0.03); }
        
        .suggested-user { padding: 8px; border: 1px solid #333; margin-bottom: 5px; text-align: left; cursor: pointer; color: #aaa; transition: 0.2s; font-size: 12px; display: flex; justify-content: space-between; }
        .suggested-user:hover { border-color: var(--neon-green); color: var(--neon-green); background: rgba(0,255,102,0.05); }

        /* TEMA SEÇİCİ CSS */
        .theme-selector { display: flex; gap: 5px; margin-top: 5px; justify-content: flex-end; }
        .theme-btn { width: 15px; height: 15px; border-radius: 2px; cursor: pointer; border: 1px solid #555; transition: transform 0.2s; }
        .theme-btn:hover { transform: scale(1.2); border-color: #fff; }
        .t-default { background: #ffcc00; }
        .t-pistachio { background: #ccff00; }
        .t-ocean { background: #00e5ff; }

        /* --- YENİ EKLENEN ÖZELLİKLER (LAYOUT BOZMAZ) --- */

        /* 1. SİBER SALDIRI / GLITCH MODU */
        body.system-breach {
            animation: glitchBody 0.2s infinite;
        }
        body.system-breach * {
            color: var(--neon-red) !important;
            border-color: var(--neon-red) !important;
            text-shadow: 2px 0 #fff, -2px 0 #000;
        }
        @keyframes glitchBody {
            0% { transform: translate(0) }
            20% { transform: translate(-2px, 2px) }
            40% { transform: translate(-2px, -2px) }
            60% { transform: translate(2px, 2px) }
            80% { transform: translate(2px, -2px) }
            100% { transform: translate(0) }
        }
        #breach-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(255, 0, 0, 0.2); z-index: 99999; pointer-events: none;
            align-items: center; justify-content: center; font-size: 50px; font-weight: bold;
            color: red; text-shadow: 0 0 20px red; letter-spacing: 10px;
        }

        /* 2. RÜTBE ETİKETLERİ */
        .rank-badge { font-size: 9px; padding: 1px 4px; margin-right: 4px; border-radius: 2px; border: 1px solid #444; vertical-align: middle; }
        .rank-caylak { color: #aaa; border-color: #aaa; }
        .rank-analist { color: var(--neon-green); border-color: var(--neon-green); background: rgba(0,255,100,0.1); }
        .rank-lord { color: var(--neon-gold); border-color: var(--neon-gold); box-shadow: 0 0 5px var(--neon-gold); }

        /* 3. GÜNÜN İTEMİ (SPOTLIGHT) */
        .spotlight-box {
            margin-bottom: 10px; border: 1px solid var(--neon-gold); 
            background: radial-gradient(circle, rgba(255,204,0,0.1) 0%, rgba(0,0,0,0) 70%);
            padding: 10px; text-align: center; position: relative;
            animation: pulseBorder 3s infinite;
        }
        .spotlight-title { color: var(--neon-gold); font-size: 14px; font-weight: bold; letter-spacing: 2px; }
        .spotlight-tip { color: #888; font-size: 10px; margin-top: 4px; font-style: italic; }
        @keyframes pulseBorder { 0% { box-shadow: 0 0 5px rgba(255,204,0,0.1); } 50% { box-shadow: 0 0 15px rgba(255,204,0,0.3); } 100% { box-shadow: 0 0 5px rgba(255,204,0,0.1); } }

        /* 4. HAFTALIK MOVERS (YAN PANEL İÇİN) */
        .movers-box {
            display: flex; justify-content: space-between; gap: 5px; margin-bottom: 10px;
        }
        .mover-item {
            flex: 1; border: 1px solid #333; padding: 5px; text-align: center; background: rgba(255,255,255,0.02);
        }
        .mover-label { font-size: 9px; display: block; margin-bottom: 2px; color: #666; }
        .mover-val { font-size: 12px; font-weight: bold; }

        /* 5. PING GÖSTERGESİ */
        .ping-display {
            position: fixed; top: 10px; right: 10px; z-index: 2000;
            font-size: 10px; color: #555; font-family: monospace;
            display: flex; align-items: center; gap: 5px;
        }
        .ping-val { color: var(--neon-green); }

        /* 6. LOG AKIŞI (CHAT ÜSTÜ) */
        .sys-log-stream {
            height: 20px; overflow: hidden; font-size: 9px; color: #444;
            border-bottom: 1px solid #222; margin-bottom: 5px; padding-left: 5px;
            display: flex; align-items: center; white-space: nowrap;
        }
        .log-line { animation: fadeLog 2s forwards; margin-right: 15px; }
        @keyframes fadeLog { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    </style>
</head>
<body>

<div class="ping-display">SAT: <span id="ping-val" class="ping-val">24ms</span></div>
<div id="breach-overlay">⚠ SYSTEM BREACH ⚠</div>

<div id="market-status-indicator">
    <div id="status-dot" class="status-dot status-open"></div>
    <span id="status-text">BORSA AÇIK</span>
</div>

<div id="confirm-modal">
    <div class="confirm-box">
        <p style="color:var(--neon-red); margin-top:0;">VERI SILINSIN MI?</p>
        <div style="display:flex; gap:10px;">
            <button id="confirm-yes" style="background:var(--neon-red); color:#000; font-weight:bold; border:none;">EVET</button>
            <button id="confirm-no" style="border-color:#444;">HAYIR</button>
        </div>
    </div>
</div>

<div id="announcement-bar"></div>

<div id="img-viewer" onclick="this.style.display='none'">
    <div class="viewer-box">
        <img id="viewer-img" src="">
        <div style="margin-top:20px; display:flex; gap:10px;">
            <a id="viewer-dl" href="" download="bordo_img.jpg" style="text-decoration:none; background:var(--neon-green); color:#000; padding:10px 20px; font-weight:bold;">İNDİR</a>
            <button onclick="document.getElementById('img-viewer').style.display='none'" style="width:auto; border-color:var(--neon-red); color:var(--neon-red);">KAPAT</button>
        </div>
    </div>
</div>

<div id="online-modal" onclick="this.style.display='none'">
    <div class="modal-content" onclick="event.stopPropagation()">
        <h3 style="color:var(--neon-gold); border-bottom:1px solid #333; padding-bottom:10px; margin-top:0;">AKTİF TERMİNALLER</h3>
        <div id="online-list" style="color:var(--neon-green); font-size:14px; text-align:left; overflow-y:auto; flex:1;"></div>
        <button onclick="document.getElementById('online-modal').style.display='none'" style="margin-top:15px; font-size:10px;">KAPAT</button>
    </div>
</div>

<div id="new-dm-modal" onclick="this.style.display='none'">
    <div class="modal-content" onclick="event.stopPropagation()">
        <h3 style="color:var(--neon-gold); border-bottom:1px solid #333; padding-bottom:10px; margin-top:0;">YENİ MESAJ BAŞLAT</h3>
        <input type="text" id="dm-target-manual" placeholder="Kullanıcı Adı Giriniz...">
        <button onclick="startDmFromInput()" style="background:var(--neon-gold); color:#000; font-weight:bold;">SOHBETİ BAŞLAT</button>
        
        <div style="border-top:1px dashed #444; margin-top:10px; padding-top:10px;">
            <small style="color:#666; display:block; margin-bottom:8px;">TANIYOR OLABİLECEĞİN KİŞİLER</small>
            <div id="registered-users-list" style="max-height: 200px; overflow-y: auto;"></div>
        </div>
        <button onclick="document.getElementById('new-dm-modal').style.display='none'" style="margin-top:15px; font-size:10px; border-color:var(--neon-red); color:var(--neon-red);">İPTAL</button>
    </div>
</div>

<div id="admin-panel">
    <h3 style="color: var(--neon-red); margin: 0 0 10px 0;">BORDO ADMIN</h3>
    <div style="border: 1px solid var(--neon-gold); padding: 5px; margin-bottom: 10px;">
        <input type="text" id="botNewsInput" placeholder="Haber Botu Mesajı..." style="margin-bottom:5px">
        <div style="display: flex; gap:5px;">
            <button onclick="pushBotNews()" style="background:var(--neon-gold); color:#000; font-weight:bold; margin:0;">BOT HABER GÖNDER</button>
            <button onclick="deleteBotNews()" style="border-color:var(--neon-red); color:var(--neon-red); margin:0;">HABERİ SİL</button>
        </div>
    </div>
    <div style="border: 1px solid var(--neon-green); padding: 5px; margin-bottom: 10px;">
        <input type="text" id="vipTargetInput" placeholder="VIP Yapılacak İsim..." style="margin-bottom:5px">
        <button onclick="giveVip()" style="border-color:var(--neon-green); color:var(--neon-green); margin:0;">VIP YETKİSİ VER</button>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px; margin-bottom: 10px; border: 1px dashed var(--neon-red); padding: 5px;">
        <button onclick="setMarketStatus(true)" style="background:var(--neon-green); color:#000; font-weight:bold; margin:0;">BORSAYI AÇ</button>
        <button onclick="setMarketStatus(false)" style="background:var(--neon-red); color:#000; font-weight:bold; margin:0;">BORSAYI DURDUR</button>
    </div>
    <button onclick="toggleBreachEffect()" style="border-color:var(--neon-red); color:var(--neon-red); margin-top:5px; width:100%">⚠ SİBER SALDIRI EFEKTİ (AÇ/KAPA)</button>
    
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px; margin-top:10px;">
        <input type="text" id="newItemName" placeholder="Ürün İsmi">
        <input type="number" id="newItemPrice" placeholder="Başlangıç G">
    </div>
    <button onclick="addItem()" style="color:var(--neon-green); border-color:var(--neon-green)">YENİ ÜRÜNÜ SİSTEME EKLE</button>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px;">
        <select id="admSelect"></select>
        <input type="number" id="admPrice" placeholder="Yeni Fiyat">
    </div>
    <button onclick="pushPrice()" style="background:var(--neon-red); color:#000; font-weight:bold;">FİYATI SABİTLE VE BAS</button>
