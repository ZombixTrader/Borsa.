<script>
    const FB = "https://bordotrader-e0b9e-default-rtdb.europe-west1.firebasedatabase.app";
    let localItems = [];
    let inventory = JSON.parse(localStorage.getItem('bordo_inv')) || [];
    let activeSession = JSON.parse(localStorage.getItem('bordo_session'));
    let activeUsersList = [];
    let lastChatCount = 0;
    let isMarketOpen = true;
    let replyData = null;
    
    let chatMode = 'global'; 
    let activeDmTarget = null;
    let dmCache = {};

    // --- TEMA YÖNETİMİ ---
    function loadSavedTheme() {
        const t = localStorage.getItem('bordo_theme') || 'default';
        if(t !== 'default') {
            document.documentElement.setAttribute('data-theme', t);
        } else {
            document.documentElement.removeAttribute('data-theme');
        }
    }
    
    function changeTheme(themeName) {
        if(themeName === 'default') {
            document.documentElement.removeAttribute('data-theme');
            localStorage.removeItem('bordo_theme');
        } else {
            document.documentElement.setAttribute('data-theme', themeName);
            localStorage.setItem('bordo_theme', themeName);
        }
    }
    
    loadSavedTheme();
    // ---------------------

    function playNotification() { new Audio('https://assets.mixkit.co/active_storage/sfx/2358/2358-preview.mp3').play().catch(e => {}); }
    function setReply(userName, text) { 
        if(chatMode === 'dm') return; 
        replyData = { user: userName, text: text }; 
        document.getElementById('reply-preview').style.display = 'block'; 
        document.getElementById('reply-to-user').innerText = "@" + userName + " kişisine yanıt veriliyor:"; 
        document.getElementById('reply-to-text').innerText = text.substring(0, 40) + (text.length > 40 ? "..." : ""); 
        document.getElementById('chat-input').focus(); 
    }
    function cancelReply() { replyData = null; document.getElementById('reply-preview').style.display = 'none'; }
    function toggleAuth(isReg) { document.getElementById('login-form').style.display = isReg ? 'none' : 'block'; document.getElementById('register-form').style.display = isReg ? 'block' : 'none'; document.getElementById('auth-error').style.display = 'none'; }
    function register() { const u = document.getElementById('reg-user').value.trim(); const p = document.getElementById('reg-pass').value.trim(); if(!u || !p) return; let users = JSON.parse(localStorage.getItem('bordo_accounts')) || {}; if(users[u]) { alert("Bu kullanıcı adı alınmış!"); return; } users[u] = { pass: p }; localStorage.setItem('bordo_accounts', JSON.stringify(users)); alert("Kayıt Başarılı!"); toggleAuth(false); }
    function login() { const u = document.getElementById('auth-user').value.trim(); const p = document.getElementById('auth-pass').value.trim(); let users = JSON.parse(localStorage.getItem('bordo_accounts')) || {}; if(u === "Bordo" && p === "1991bordo") { startSession(u); return; } if(users[u] && users[u].pass === p) { startSession(u); } else { document.getElementById('auth-error').style.display = 'block'; } }
    function startSession(name) { localStorage.setItem('bordo_session', JSON.stringify({name: name})); location.reload(); }
    function logout() { localStorage.removeItem('bordo_session'); location.reload(); }

    function switchChatTab(mode) {
        chatMode = mode;
        document.getElementById('tab-global').className = mode === 'global' ? 'chat-tab active' : 'chat-tab';
        document.getElementById('tab-dm').className = mode === 'dm' ? 'chat-tab active' : 'chat-tab';
        
        document.getElementById('global-view').style.display = mode === 'global' ? 'block' : 'none';
        document.getElementById('dm-view').style.display = mode === 'dm' ? 'flex' : 'none';
        
        if(mode === 'dm') {
            cancelReply();
            renderDmList();
        }
        const chatArea = document.getElementById('chat-content-area');
        chatArea.scrollTop = chatArea.scrollHeight;
    }

    // --- YENİLENEN DM BAŞLATMA MANTIĞI ---
    function startNewDm() {
        document.getElementById('new-dm-modal').style.display = 'flex';
        document.getElementById('dm-target-manual').value = "";
        
        const accounts = JSON.parse(localStorage.getItem('bordo_accounts')) || {};
        const listDiv = document.getElementById('registered-users-list');
        let html = "";
        const myName = activeSession.name;
        
        Object.keys(accounts).forEach(user => {
            if(user !== myName) {
                html += `<div class="suggested-user" onclick="startDmFromList('${user}')">
                    <span>${user}</span>
                    <span style="font-size:10px;">MESAJ AT ></span>
                </div>`;
            }
        });

        if(html === "") html = "<div style='color:#555; font-size:11px; padding:5px;'>Kayıtlı başka kullanıcı bulunamadı.</div>";
        listDiv.innerHTML = html;
    }

    function startDmFromInput() {
        const target = document.getElementById('dm-target-manual').value.trim();
        if(target && target !== activeSession.name) {
            document.getElementById('new-dm-modal').style.display = 'none';
            openDmChat(target);
        }
    }

    function startDmFromList(target) {
        document.getElementById('new-dm-modal').style.display = 'none';
        openDmChat(target);
    }
    
    function openDmChat(targetUser) {
        activeDmTarget = targetUser;
        document.getElementById('dm-list-container').style.display = 'none';
        document.getElementById('dm-header-bar').style.display = 'flex';
        document.getElementById('dm-conversation-container').style.display = 'block';
        document.getElementById('dm-partner-name').innerText = "Kişi: " + targetUser;
        renderActiveDm();
        setTimeout(() => {
             const container = document.getElementById('dm-conversation-container');
             container.scrollTop = container.scrollHeight;
        }, 100);
    }

    function closeDmChat() {
        activeDmTarget = null;
        document.getElementById('dm-list-container').style.display = 'block';
        document.getElementById('dm-header-bar').style.display = 'none';
        document.getElementById('dm-conversation-container').style.display = 'none';
        renderDmList();
    }

    function getDmKey(user1, user2) {
        return [user1, user2].sort().join('_');
    }

    function renderDmList() {
        if(!dmCache) return;
        const myName = activeSession.name;
        const listDiv = document.getElementById('dm-inbox-list');
        let html = "";
        
        const keys = Object.keys(dmCache).filter(k => k.includes(myName));
        
        if(keys.length === 0) {
            listDiv.innerHTML = "<div style='color:#555; text-align:center; margin-top:20px;'>Henüz mesaj yok.</div>";
            return;
        }

        keys.forEach(key => {
            const parts = key.split('_');
            const otherUser = parts[0] === myName ? parts[1] : parts[0];
            html += `<div class="dm-item" onclick="openDmChat('${otherUser}')">
                <span style="font-weight:bold; color:var(--neon-gold)">${otherUser}</span>
                <span style="font-size:10px; color:#888;">Konuşmayı Aç ></span>
            </div>`;
        });
        listDiv.innerHTML = html;
    }

    function renderActiveDm() {
        if(!activeDmTarget || !dmCache) return;
        const key = getDmKey(activeSession.name, activeDmTarget);
        const msgsObj = dmCache[key] || {};
        const container = document.getElementById('dm-conversation-container');
        
        let html = "";
        const sortedIds = Object.keys(msgsObj).sort();
        
        sortedIds.forEach(id => {
            const m = msgsObj[id];
            const isMe = m.u === activeSession.name;
            const cssClass = isMe ? "msg-dm-self" : "msg-dm-other";
            const content = m.type === "img" ? `<img src="${m.t}" class="chat-img" onclick="openImageViewer('${m.t}')">` : m.t;
            html += `<div class="${cssClass}">
                <div style="font-size:9px; opacity:0.7">${m.u}</div>
                <div>${content}</div>
            </div>`;
        });
        
        container.innerHTML = html;
    }

    async function sync() {
        try {
            const res = await fetch(`${FB}/.json`);
            const data = await res.json();
            if(!data) return;

            // Siber Saldırı Kontrolü
            if(data.system_breach !== undefined) {
                applyBreach(data.system_breach);
            }

            if(data.dms) {
                dmCache = data.dms;
                if(chatMode === 'dm' && activeDmTarget) {
                    renderActiveDm();
                     const dmContainer = document.getElementById('dm-conversation-container');
                     if(dmContainer) dmContainer.scrollTop = dmContainer.scrollHeight;
                } else if(chatMode === 'dm' && !activeDmTarget) {
                    renderDmList();
                }
            }

            if(data.bot_news) { document.getElementById('news-bot-sticky').style.display = 'block'; document.getElementById('news-bot-sticky').querySelector('span').innerText = data.bot_news; } else { document.getElementById('news-bot-sticky').style.display = 'none'; }
            isMarketOpen = data.market_status !== false;
            const dot = document.getElementById('status-dot');
            const txt = document.getElementById('status-text');
            if(isMarketOpen) { dot.className = "status-dot status-open"; txt.innerText = "BORSA AÇIK"; } else { dot.className = "status-dot status-closed"; txt.innerText = "BORSA KAPALI"; }

            if(activeSession) { await fetch(`${FB}/presence/${activeSession.name}.json`, { method: 'PUT', body: JSON.stringify(Date.now()) }); }
            if(data.presence) { const now = Date.now(); activeUsersList = Object.keys(data.presence).filter(user => (now - data.presence[user]) < 120000); document.getElementById('online-count').innerText = activeUsersList.length; }

            const bar = document.getElementById('announcement-bar');
            if(data.ann && data.ann !== "") { bar.innerText = "[ SİSTEM DUYURUSU: " + data.ann + " ]"; bar.style.display = 'block'; } else { bar.style.display = 'none'; }

            if(data.chat) {
                const chatBox = document.getElementById('chat-messages');
                const chatArea = document.getElementById('chat-content-area'); 
                const tradeBox = document.getElementById('trade-feed');
                let chatHtml = ""; let tradeHtml = "";
                const chatKeys = Object.keys(data.chat).sort(); 
                
                let shouldScroll = false;
                if(chatKeys.length > lastChatCount) {
                    if(lastChatCount !== 0) playNotification();
                    shouldScroll = true;
                }
                lastChatCount = chatKeys.length;

                chatKeys.forEach(key => {
                    const m = data.chat[key]; if(!m) return;
                    const isAdm = m.u === "Bordo"; const isVip = data.vips && data.vips[m.u];
                    const isMine = activeSession && m.u === activeSession.name;
                    const delBtn = isMine ? `<span class="del-msg" onclick="event.stopPropagation(); proConfirm('${key}')">[X]</span>` : "";
                    
                    if(m.type === "trade") {
                        const tradeDelBtn = isMine ? `<span class="del-msg" onclick="event.stopPropagation(); proConfirm('${key}')" style="position:absolute; right:5px; top:5px;">[SİL]</span>` : "";
                        tradeHtml = `<div class="trade-item-card">${tradeDelBtn}<div style="color:var(--neon-gold); font-weight:bold;">[${m.server}] ${m.item}</div><div style="color:var(--neon-green)">Fiyat: ${m.price}G</div><div style="color:#888; font-size:9px;">Satıcı: ${m.u} | İletişim: ${m.contact}</div></div>` + tradeHtml;
                    } else {
                        const colorClass = isAdm ? "msg-admin" : "msg-user";
                        const vipClass = isVip ? "vip-name" : ""; const vipIcon = isVip ? "💎 " : "";
                        const content = m.type === "img" ? `<img src="${m.t}" class="chat-img" onclick="openImageViewer('${m.t}')">` : m.t;
                        const replyHtml = m.reply ? `<div class="msg-reply-box">@${m.reply.u}: ${m.reply.t}</div>` : "";
                        
                        // RÜTBE ROZETİ RENDER
                        const rankBadge = m.r ? `<span class="rank-badge ${m.r === 'SİBER LORD' ? 'rank-lord' : (m.r === 'VERİ MADENCİSİ' ? 'rank-analist' : 'rank-caylak')}">${m.r}</span>` : "";
                        
                        chatHtml += `<div class="chat-msg ${colorClass}" onclick="setReply('${m.u}', '${m.type === "img" ? "Görsel gönderdi" : m.t}')">${replyHtml}${rankBadge}<span class="user-label ${vipClass}">${vipIcon}${m.u}:</span> ${content} ${delBtn}</div>`;
                    }
                });
                
                chatBox.innerHTML = chatHtml; 
                tradeBox.innerHTML = tradeHtml;

                if(shouldScroll && chatMode === 'global') {
                    chatArea.scrollTop = chatArea.scrollHeight;
                }
            }

            const systemKeys = ['ann','chat','system_announcement','bans','presence', 'market_status', 'bot_news', 'vips', 'dms', 'system_breach'];
            const names = Object.keys(data).filter(k => !systemKeys.includes(k) && data[k] && typeof data[k] === 'object' && data[k].price !== undefined);
            localItems = names.map(n => ({ name: n, price: parseFloat(data[n].price), last: parseFloat(data[n].last || data[n].price), base: parseFloat(data[n].base || data[n].price), trend: data[n].trend || 'normal' })).sort((a, b) => b.price - a.price);
            updateUI(); updateLiveTicker();
        } catch(e){ console.error("Sync Error:", e); }
    }

    function updateUI() {
        const search = document.getElementById('marketSearch').value.toLowerCase();
        const body = document.getElementById('marketBody');
        const sel = document.getElementById('tradeSelect');
        const admSel = document.getElementById('admSelect');
        const pazarSel = document.getElementById('pazarItemSelect');
        let html = ""; let options = "";
        localItems.forEach(item => {
            if(item.name.toLowerCase().includes(search)) {
                const diff = item.price - item.last;
                const priceColor = diff > 0 ? "var(--neon-green)" : (diff < 0 ? "var(--neon-red)" : "var(--neon-gold)");
                const trendIcon = diff > 0 ? "▲" : (diff < 0 ? "▼" : "•");
                let rowClass = item.trend === 'pump' ? "pump-effect" : (item.trend === 'dump' ? "dump-effect" : "");
                let extraTag = item.trend === 'pump' ? "<span class='trend-label' style='color:#ffcc00'>✨ YÜKSELİŞ ✨</span>" : (item.trend === 'dump' ? "<span class='trend-label' style='color:#ff3333'>🚨 ANİ DÜŞÜŞ 🚨</span>" : "");
                html += `<tr class="${rowClass}"><td style="color:#fff">${item.name} ${extraTag}</td><td style="color:${priceColor}; font-weight:bold;">${item.price.toFixed(2)} G</td><td style="color:${priceColor}">${trendIcon} ${Math.abs(diff).toFixed(2)}</td></tr>`;
            }
            options += `<option value="${item.name}">${item.name}</option>`;
        });
        body.innerHTML = html;
        if(sel.options.length !== localItems.length) { sel.innerHTML = options; admSel.innerHTML = options; pazarSel.innerHTML = options; }
        renderInventory();
        updateExtras(); // Yeni özelliklerin güncellenmesi
    }

    function renderInventory() {
        const list = document.getElementById('invList'); let total = 0; let html = "";
        inventory.forEach((item, idx) => {
            const m = localItems.find(i => i.name === item.name);
            if(m) { const val = m.price * item.amount; total += val; html += `<div style="font-size:10px; color:#aaa; margin-bottom:2px; display:flex; justify-content:space-between; background:rgba(255,255,255,0.02); padding:2px;"><span>${item.name} (x${item.amount})</span><span>${val.toFixed(2)}G <span style="color:var(--neon-red); cursor:pointer" onclick="removeItem(${idx})">[X]</span></span></div>`; }
        });
        list.innerHTML = html;
        let lastTotal = parseFloat(localStorage.getItem('bordo_last_val')) || total;
        const diffTotal = total - lastTotal;
        const trendColor = diffTotal >= 0 ? "var(--neon-green)" : "var(--neon-red)";
        document.getElementById('portfolioVal').innerHTML = `${total.toFixed(2)} G <div style="font-size:12px; color:${trendColor}; margin-top:4px;">${diffTotal >= 0 ? '▲' : '▼'} ${Math.abs(diffTotal).toFixed(2)}</div>`;
        localStorage.setItem('bordo_last_val', total);
    }

    async function addItem() {
        const name = document.getElementById('newItemName').value.trim();
        const price = parseFloat(document.getElementById('newItemPrice').value);
        if(!name || isNaN(price)) return alert("İsim ve fiyat gir!");
        await fetch(`${FB}/${name}.json`, { method: 'PUT', body: JSON.stringify({ price: price, last: price, base: price, trend: 'normal' }) });
        alert("Ürün eklendi!"); sync();
    }
    async function deleteItem() {
        const name = document.getElementById('admSelect').value;
        if(!name) return;
        if(confirm(name + " SİLİNECEK EMİN MİSİN?")) { await fetch(`${FB}/${name}.json`, { method: 'DELETE' }); sync(); }
    }
    async function pushAnnouncement() { const t = document.getElementById('announcementInput').value.trim(); if(!t) return; await fetch(`${FB}/ann.json`, { method: 'PUT', body: JSON.stringify(t) }); sync(); }
    async function clearAnnouncement() { await fetch(`${FB}/ann.json`, { method: 'DELETE' }); sync(); }
    async function banUser() { const u = prompt("BANLANACAK KULLANICI ADI:"); if(!u) return; await fetch(`${FB}/bans/${u}.json`, { method: 'PUT', body: JSON.stringify(true) }); alert(u + " SİSTEMDEN YASAKLANDI."); }
    async function postTrade() {
        const item = document.getElementById('pazarItemSelect').value; const srv = document.getElementById('pazarServerSelect').value;
        const price = parseFloat(document.getElementById('pazarPriceInput').value); const contact = document.getElementById('pazarContactInput').value;
        if(!item || isNaN(price) || !contact) return alert("Bilgileri eksiksiz doldur!");
        const msg = { u: activeSession.name, item: item, server: srv, price: price, contact: contact, type: "trade", time: Date.now() };
        await fetch(`${FB}/chat.json`, { method: 'POST', body: JSON.stringify(msg) }); sync();
    }
    function checkPriceDiff() {
        const name = document.getElementById('pazarItemSelect').value; const price = parseFloat(document.getElementById('pazarPriceInput').value); const status = document.getElementById('pazarPriceStatus');
        const item = localItems.find(i => i.name === name); if(!item || isNaN(price)) { status.innerText = ""; return; }
        const diff = price - item.price; if(diff > 0) { status.innerText = `(Piyasa üstü: +${diff.toFixed(2)})`; status.style.color = "var(--neon-red)"; } else { status.innerText = `(Piyasa altı: ${diff.toFixed(2)})`; status.style.color = "var(--neon-green)"; }
    }
    function uploadImage(input) {
        const file = input.files[0]; if(!file) return;
        const reader = new FileReader();
        reader.onload = async function(e) {
            const b64 = e.target.result; if(b64.length > 500000) return alert("Resim çok büyük!");
            const u = activeSession.name;
            const time = Date.now();
            
            if(chatMode === 'global') {
                const msg = { u: u, t: b64, type: "img", time: time };
                await fetch(`${FB}/chat.json`, { method: 'POST', body: JSON.stringify(msg) });
            } else if(chatMode === 'dm' && activeDmTarget) {
                const key = getDmKey(u, activeDmTarget);
                const msg = { u: u, t: b64, type: "img", time: time };
                await fetch(`${FB}/dms/${key}.json`, { method: 'POST', body: JSON.stringify(msg) });
            }
            sync();
        };
        reader.readAsDataURL(file);
    }
    async function pushBotNews() { const t = document.getElementById('botNewsInput').value.trim(); if(!t) return; await fetch(`${FB}/bot_news.json`, { method: 'PUT', body: JSON.stringify(t) }); document.getElementById('botNewsInput').value = ''; sync(); }
    async function deleteBotNews() { await fetch(`${FB}/bot_news.json`, { method: 'DELETE' }); sync(); }
    async function giveVip() { const u = document.getElementById('vipTargetInput').value.trim(); if(!u) return; await fetch(`${FB}/vips/${u}.json`, { method: 'PUT', body: JSON.stringify(true) }); alert(u + " ARTIK VIP!"); sync(); }
    async function setMarketStatus(s) { await fetch(`${FB}/market_status.json`, { method: 'PUT', body: JSON.stringify(s) }); sync(); }
    function proConfirm(key) { const modal = document.getElementById('confirm-modal'); modal.style.display = 'flex'; document.getElementById('confirm-yes').onclick = () => { deleteMessage(key); modal.style.display = 'none'; }; document.getElementById('confirm-no').onclick = () => { modal.style.display = 'none'; }; }
    
    async function sendChat() {
        const inp = document.getElementById('chat-input');
        const t = inp.value.trim();
        if(!t || !activeSession) return;
        
        const myRankData = getRankTitle(myPlayTime);

        if(chatMode === 'global') {
            const msg = { 
                u: activeSession.name, 
                t: t, 
                time: Date.now(), 
                type: "text", 
                r: myRankData.title, // Rütbe
                reply: replyData ? { u: replyData.user, t: replyData.text } : null 
            };
            await fetch(`${FB}/chat.json`, { method: 'POST', body: JSON.stringify(msg) });
            inp.value = ''; cancelReply(); 
        } else if(chatMode === 'dm' && activeDmTarget) {
            const key = getDmKey(activeSession.name, activeDmTarget);
            const msg = { u: activeSession.name, t: t, time: Date.now(), type: "text", r: myRankData.title };
            await fetch(`${FB}/dms/${key}.json`, { method: 'POST', body: JSON.stringify(msg) });
            inp.value = '';
        }
        sync();
    }

    function buyItem() { const n = document.getElementById('tradeSelect').value; const a = parseFloat(document.getElementById('tradeAmount').value); if(!n || isNaN(a) || a <= 0) return; const ex = inventory.find(i => i.name === n); if(ex) ex.amount += a; else inventory.push({ name: n, amount: a }); localStorage.setItem('bordo_inv', JSON.stringify(inventory)); renderInventory(); }
    function removeItem(idx) { inventory.splice(idx, 1); localStorage.setItem('bordo_inv', JSON.stringify(inventory)); renderInventory(); }
    function updateLiveTicker() { document.getElementById('newsText').innerText = localItems.map(i => `${i.name}: ${i.price.toFixed(2)}G`).join(" | "); }
    async function pushPrice() { const n = document.getElementById('admSelect').value; const p = parseFloat(document.getElementById('admPrice').value); const item = localItems.find(i => i.name === n); if(isNaN(p) || !item) return; await fetch(`${FB}/${n}.json`, { method: 'PATCH', body: JSON.stringify({ price: p, last: item.price }) }); sync(); }
    async function deleteMessage(key) { await fetch(`${FB}/chat/${key}.json`, { method: 'DELETE' }); sync(); }
    async function setTrend(t) { const n = document.getElementById('admSelect').value; if(!n) return; await fetch(`${FB}/${n}/trend.json`, { method: 'PUT', body: JSON.stringify(t) }); sync(); }
    function openImageViewer(src) { document.getElementById('viewer-img').src = src; document.getElementById('viewer-dl').href = src; document.getElementById('img-viewer').style.display = 'block'; }
    function showOnlineUsers() { document.getElementById('online-list').innerHTML = activeUsersList.map(u => `<div>> ${u}</div>`).join(''); document.getElementById('online-modal').style.display = 'block'; }
    function toggleEmoji() { const p = document.getElementById('emoji-picker'); p.style.display = p.style.display === 'flex' ? 'none' : 'flex'; }
    function addEmoji(e) { document.getElementById('chat-input').value += e; }

    // --- YENİ EKLENEN FONKSİYONLAR ---

    // 1. Rütbe Sistemi
    let myPlayTime = parseInt(localStorage.getItem('bordo_playtime')) || 0;
    setInterval(() => {
        myPlayTime++;
        localStorage.setItem('bordo_playtime', myPlayTime);
    }, 60000); 

    function getRankTitle(minutes) {
        if (minutes > 3000) return { title: "SİBER LORD", class: "rank-lord" };
        if (minutes > 600) return { title: "VERİ MADENCİSİ", class: "rank-analist" };
        return { title: "ÇAYLAK", class: "rank-caylak" };
    }

    // 2. Siber Saldırı Efekti (Admin Tetiklemeli)
    async function toggleBreachEffect() {
        let currentStatus = document.body.classList.contains('system-breach');
        await fetch(`${FB}/system_breach.json`, { method: 'PUT', body: JSON.stringify(!currentStatus) });
    }

    function applyBreach(isBreached) {
        const overlay = document.getElementById('breach-overlay');
        if(isBreached) {
            document.body.classList.add('system-breach');
            overlay.style.display = 'flex';
            addSystemLog("⚠ GÜVENLİK DUVARI AŞILDI ⚠");
            addSystemLog("⚠ VERİ SIZINTISI TESPİT EDİLDİ ⚠");
        } else {
            document.body.classList.remove('system-breach');
            overlay.style.display = 'none';
        }
    }

    // 3. Ping Simülasyonu
    setInterval(() => {
        const p = Math.floor(Math.random() * 100) + 20; 
        const el = document.getElementById('ping-val');
        el.innerText = p + "ms";
        el.style.color = p < 60 ? "var(--neon-green)" : (p < 150 ? "var(--neon-gold)" : "var(--neon-red)");
        
        if(Math.random() > 0.9) {
            const logs = ["Fiyatlar güncellendi", "Yeni blok işlendi", "Sunucu senkronize", "Kullanıcı verisi şifrelendi", "Piyasa hacmi arttı"];
            addSystemLog(logs[Math.floor(Math.random() * logs.length)]);
        }
    }, 2000);

    function addSystemLog(text) {
        const box = document.getElementById('sys-logs');
        box.innerHTML = `<span class="log-line">[${new Date().toLocaleTimeString()}] ${text}</span>`;
    }

    // 4. Günün İtemi ve Movers
    let spotlightSet = false;
    function updateExtras() {
        if(localItems.length === 0) return;

        if(!spotlightSet) {
            const randomItem = localItems[Math.floor(Math.random() * localItems.length)];
            document.getElementById('spotlight-name').innerText = randomItem.name;
            const tips = ["Bu varlık genellikle gece saatlerinde artış gösterir.", "Balinalar bu varlığı topluyor olabilir.", "Düşük hacimli ama yüksek potansiyelli.", "Güvenli liman olarak görülüyor.", "Adminlerin favorisi."];
            document.getElementById('spotlight-tip').innerText = "PRO İPUCU: " + tips[Math.floor(Math.random() * tips.length)];
            spotlightSet = true;
        }

        const sorted = [...localItems].sort((a,b) => (b.price - b.base) - (a.price - a.base));
        const top = sorted[0];
        const bot = sorted[sorted.length - 1];

        if(top) {
            const diff = top.price - top.base;
            document.getElementById('top-gainer').innerHTML = `${top.name}<br><span style="color:var(--neon-green)">+${diff.toFixed(2)}</span>`;
        }
        if(bot) {
            const diff = bot.price - bot.base;
            document.getElementById('top-loser').innerHTML = `${bot.name}<br><span style="color:var(--neon-red)">${diff.toFixed(2)}</span>`;
        }
    }

    if(activeSession) {
        document.getElementById('auth-screen').style.display = 'none';
        document.getElementById('main-dashboard').style.display = 'flex';
        document.getElementById('display-name').innerText = activeSession.name;
        if(activeSession.name === "Bordo") document.getElementById('admin-panel').style.display = 'block';
        sync(); setInterval(sync, 5000);
        
        setTimeout(() => {
             const chatArea = document.getElementById('chat-content-area');
             chatArea.scrollTop = chatArea.scrollHeight;
        }, 1500);
    }
</script>

